# Copy to .env.local for local dev. For production, set these in
# Vercel → Settings → Environment Variables.

# FastAPI backend base URL. The Next.js app uses NEXT_PUBLIC_API_URL
# (any var prefixed NEXT_PUBLIC_ is inlined into the client bundle at
# build time). For local dev you can point at a tunnel or localhost:8000.
NEXT_PUBLIC_API_URL=https://dress-live-boutique-production.up.railway.app

# When you later build the bride call page, set the LiveKit URL too:
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit.livekit.cloud
