{
  "expo": {
    "name": "Dress Live Partner",
    "slug": "boutique-partner",
    "version": "1.0.1",
    "owner": "atul_kumar007",
    "orientation": "portrait",
    "icon": "./assets/images/newsellericon.png",
    "scheme": "dress-live-partner",
    "userInterfaceStyle": "automatic",
    "ios": {
      "jsEngine": "hermes",
      "supportsTablet": true,
      "newArchEnabled": true,
      "bundleIdentifier": "com.atul.boutique.partner",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "Dress Live Partner needs camera access so you can show yourself to the customer during a live fitting call.",
        "NSMicrophoneUsageDescription": "Dress Live Partner needs microphone access so you can talk to the customer during a live fitting call."
      }
    },
    "android": {
      "jsEngine": "hermes",
      "newArchEnabled": true,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/newsellericon.png",
        "monochromeImage": "./assets/images/newsellericon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.atul.boutique.partner",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "jsEngine": "jsc",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/newsellericon.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/newsellericon.png",
          "color": "#1A1A1A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Dress Live Partner uses your camera so the customer can see you during the live fitting call.",
          "microphonePermission": "Dress Live Partner uses your microphone so you can talk to the customer during the call."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4533a2d6-e03f-4e32-b63b-fc93a4d92aa8"
      }
    }
  }
}
