{
  "expo": {
    "name": "Dress Live",
    "slug": "frontend",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/dress-live-icon.png",
    "scheme": "dress-live",
    "userInterfaceStyle": "automatic",
    "ios": {
      "jsEngine": "hermes",
      "supportsTablet": true,
      "newArchEnabled": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Dress Live needs camera access so a stylist can see you on a live video call and the AI can render dresses on your live video.",
        "NSMicrophoneUsageDescription": "Dress Live needs microphone access so you can talk to your stylist during a live video call."
      },
      "bundleIdentifier": "com.atul.customer.app"
    },
    "android": {
      "jsEngine": "hermes",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#F4DCDC",
        "foregroundImage": "./assets/images/dress-live-icon-foreground.png",
        "monochromeImage": "./assets/images/dress-live-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.atul.customer.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "jsEngine": "jsc",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dress-live-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Dress Live to access your location so we can show your current area."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dress Live to access your photos so you can upload a profile picture."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Dress Live uses your camera so a stylist can see you on the live video call and the AI can dress you in real time.",
          "microphonePermission": "Dress Live uses your microphone so you can talk to your stylist during the call."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Dress Live to read your latest photos so you can quickly pick one for AI try-on.",
          "savePhotosPermission": "Allow Dress Live to save photos so you can keep your AI try-on previews.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/dress-live-icon-foreground.png",
          "color": "#1A1A1A"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.atul.customer.app",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ed0be65-298e-4dc6-bc7b-21618ea7ff8b"
      }
    },
    "owner": "atul_kumar007"
  }
}
