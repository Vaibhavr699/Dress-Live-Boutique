{
  "$schema": "https://schema.railpack.com",
  "deploy": {
    "aptPackages": [
      "libgl1",
      "libegl1",
      "libglib2.0-0",
      "libsm6",
      "libxext6",
      "libxrender1",
      "libxcb1",
      "libgomp1"
    ],
    "startCommand": "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
