# Copy to .env for local dev, or set these in Railway → Variables.
#
# Minimum for Railway deploy (2 variables):
#   SECRET_KEY=...          # openssl rand -hex 32
#   DATABASE_URL=...        # Supabase → Project Settings → Database → Connection string (URI)
#
# Alternative (6 variables) if you prefer discrete fields:
#   POSTGRES_SERVER=db.xxxxx.supabase.co
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=...
#   POSTGRES_DB=postgres

PROJECT_NAME=Dress Live Boutique API
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database (pick one style)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# POSTGRES_SERVER=db.xxxxx.supabase.co
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=postgres

# CORS — comma-separated origins for web/mobile clients
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Supabase storage (profile images, dress photos)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Email (password reset OTP)
RESEND_API_KEY=

# LiveKit (video calls)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Public base URL of the Next.js bride call page. Bride confirmation emails
# include `{WEB_CALL_BASE_URL}/call/{booking_id}?token=<JWT>`. Leave empty
# for RN-only deployments — emails simply skip the link.
WEB_CALL_BASE_URL=https://app.dresslive.app

# Virtual try-on
FASHN_API_KEY=
BODYGRAM_API_KEY=
BODYGRAM_ORG_ID=

# Decart realtime VTON (Lucy 2.1) — server-side only, NEVER expose to clients.
# `DECART_API_KEY` mints short-lived client tokens; the SDK gets the short tokens.
DECART_API_KEY=
DECART_REALTIME_MODEL=lucy-2.1-vton
# Optional knobs (defaults are sensible):
# DECART_CLIENT_TOKEN_TTL_MINUTES=90
# DECART_MAX_SESSION_SECONDS=5400
# DECART_DAILY_BUDGET_USD=100
# DECART_PER_BOOKING_SECONDS_LIMIT=5400
# DECART_COST_PER_SECOND_USD=0.02

# RunPod GPU try-on (optional)
RUNPOD_ENABLED=false
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
