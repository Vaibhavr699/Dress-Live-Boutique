# Copy to .env for local dev, or set these in Railway → Variables.
#
# Minimum for Railway deploy (2 variables):
#   SECRET_KEY=...          # openssl rand -hex 32
#   DATABASE_URL=...        # Supabase → Project Settings → Database → Connection string (URI)
#
# Alternative (6 variables) if you prefer discrete fields:
#   POSTGRES_SERVER=db.xxxxx.supabase.co
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=...
#   POSTGRES_DB=postgres

PROJECT_NAME=Dress Live Boutique API
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database (pick one style)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# POSTGRES_SERVER=db.xxxxx.supabase.co
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=postgres

# CORS — comma-separated origins for web/mobile clients
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Supabase storage (profile images, dress photos)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Email (password reset OTP)
RESEND_API_KEY=

# LiveKit (video calls)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Virtual try-on
FASHN_API_KEY=
BODYGRAM_API_KEY=
BODYGRAM_ORG_ID=

# RunPod GPU try-on (optional)
RUNPOD_ENABLED=false
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
